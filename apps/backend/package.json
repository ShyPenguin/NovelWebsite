{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "npm run docker:reset && node --env-file=.env.dev --import tsx scripts/dev.js",
    "clean:local": "rimraf dist && npm run docker:down",
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:local": "npm run docker:reset && node --env-file=.env.dev --import tsx scripts/dev.js && node dist/server.js",
    "db:push": "drizzle-kit push",
    "stage:db:generate": "tsx ../../node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.stage.ts",
    "stage:db:migrate": "drizzle-kit migrate --config=drizzle.config.stage.ts",
    "stage:db:seed": "tsx --env-file=.env.stage seed/seed-stage.ts",
    "dev:db:migrate": "drizzle-kit migrate --config=drizzle.config.dev.ts",
    "dev:db:generate": "tsx ../../node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.dev.ts",
    "dev:db:seed": "tsx seed/seed-frontend.js && tsx seed/seed-storage.js",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down -v",
    "docker:reset": "npm run docker:down  && npm run docker:up",
    "docker:db:access": "docker exec -it novelwebsite_dev_psql psql -U dev -d novelwebsite_dev_db",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f postgres",
    "docker:clean": "npm run docker:down && docker volume prune -f && npm run dev",
    "test": "npm run test:unit && npm run test:int",
    "test:int": "npm run docker:test:down && npm run docker:test:up && wait-on tcp:5435 && tsx scripts/database-template.js && vitest run --project integration && npm run docker:test:down",
    "test:unit": "vitest run --project unit",
    "test:build": "npm run docker:test:up && wait-on tcp:5435 && tsx scripts/database-template.js",
    "test:clean": "npm run docker:test:down",
    "docker:test:up": "docker compose -f docker-compose.test.yml up -d",
    "docker:test:down": "docker compose -f docker-compose.test.yml down -v",
    "check-remote-db": "tsx scripts/check-remote-db.ts"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@googleapis/docs": "^8.1.1",
    "@repo/contracts": "*",
    "@repo/typescript-config": "*",
    "@supabase/supabase-js": "^2.89.0",
    "@upstash/redis": "^1.34.9",
    "bcrypt-ts": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "path": "^0.12.7",
    "pg": "^8.13.3",
    "uuid": "^11.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@repo/typescript-config": "*",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.4",
    "mime-types": "^3.0.2",
    "nodemon": "^3.1.9",
    "redis": "^5.10.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  }
}
