{
  "name": "@repo/contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./dto": {
      "types": "./dist/dto/index.d.ts",
      "default": "./dist/dto/index.js"
    },
    "./dto/*": {
      "types": "./dist/dto/*.d.ts",
      "default": "./dist/dto/*.js"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*/schema.d.ts",
      "default": "./dist/schemas/*/schema.js"
    },
    "./utils/*": {
      "types": "./dist/utils/export/*/index.d.ts",
      "default": "./dist/utils/export/*/index.js"
    },
    "./constants": {
      "types": "./dist/constants/export/index.d.ts",
      "default": "./dist/constants/export/index.js"
    },
    "./fields/*": {
      "types": "./dist/fields/export/*/index.d.ts",
      "default": "./dist/fields/export/*/index.js"
    },
    "./auth/permissions/*": {
      "types": "./dist/auth/permissions/*.d.ts",
      "default": "./dist/auth/permissions/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json && (concurrently \"tsc -p tsconfig.build.json -w\" \"tsc-alias -p tsconfig.build.json -w\")",
    "test": "vitest run"
  },
  "dependencies": {
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "concurrently": "^9.2.1",
    "tsc-alias": "^1.8.16",
    "vitest": "^4.0.18"
  },
  "typesVersions": {
    "*": {
      "api/*": [
        "dist/api/*"
      ],
      "schemas/*": [
        "dist/schemas/*"
      ]
    }
  }
}
