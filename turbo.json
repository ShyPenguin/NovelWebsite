{
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "persistent": false,
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "start:local": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "clean:local": {},
    "docker:down": {
      "cache": false
    },
    "docker:with-nginx:run": { "persistent": true, "cache": false }
  }
}
