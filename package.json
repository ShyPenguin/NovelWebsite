{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "test": "turbo run test",
    "start:local": "turbo run start:local",
    "build:frontend":"turbo run build -F=@repo/contracts -F=frontend",
    "build:backend":"turbo run build -F=@repo/contracts -F=backend",
    "start:backend": "node apps/backend/dist/server.js",
    "clean:local": "turbo run clean:local",
    "docker:down": "turbo run docker:down --filter=backend"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.16",
    "turbo": "^2.7.5",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "typescript": "~5.8.3"
  },
  "packageManager": "npm@10.8.2"
}
